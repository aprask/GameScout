<div id="<%= dom_id game %>">
  <p>
    <strong>Igdb:</strong>
    <%= game.igdb_id %>
  </p>

  <p>
    <strong>Name:</strong>
    <%= game.name %>
  </p>

  <p>
    <strong>Summary:</strong>
    <%= game.summary %>
  </p>

  <p>
    <strong>Storyline:</strong>
    <%= game.storyline %>
  </p>

  <p>
    <strong>Rating:</strong>
    <%= game.rating %>
  </p>

  <p>
    <strong>Popularity:</strong>
    <%= game.popularity %>
  </p>

</div>
